# ===================================================================
#  Environment variables consumed by the application.
#
#  Copy this file to `.env` in the project root and fill in your
#  local values.  `.env` is gitignored and will NOT be committed.
#
#    cp .env.example .env
#
#  Docker Compose also reads `.env` automatically  for its
#  ${VAR} substitutions (see docker-compose.yml).
# ===================================================================

# ---- Database ----
# Local PostgreSQL on default port.
DB_URL=jdbc:postgresql://localhost:5432/learning_academy
DB_USERNAME=postgres
DB_PASSWORD=change_me

# ---- Redis (optional for local dev — default cache is "simple") ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- JWT ----
# Generate a 256-bit hex key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRATION=86400000

# ---- Server ----
SERVER_PORT=8080
